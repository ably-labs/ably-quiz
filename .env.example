# Copy to .env.local (gitignored) and fill in what you have.
# Missing keys are skipped gracefully — see CLAUDE.md.

# --- AI models — all agents answer through the Vercel AI Gateway (one key) ---
AI_GATEWAY_API_KEY=         # required for agents — unified billing/routing for every provider
                            # (https://vercel.com/docs/ai-gateway). Models addressed as provider/model.
ANTHROPIC_API_KEY=          # only for GROUNDED turns — the MCP connector is a direct-Anthropic
                            # feature the gateway can't carry, so grounded Anthropic turns bypass it.
# OPENAI_API_KEY / XAI_API_KEY are no longer needed — those providers route through the gateway.

# --- Ably (needed from S1) ---
ABLY_API_KEY=               # server-side only; never NEXT_PUBLIC_*

# --- MCP grounding (optional) — lets agents look up your company knowledge ---
# Point this at YOUR MCP server's /mcp endpoint to enable (a) in-quiz grounding
# (host signs in via OAuth in-app) and (b) `pnpm agents:study` (richer cribs).
# Leave it unset and agents simply play on their own knowledge — the grounding UI
# hides itself. There is no default; nothing internal ships in the repo.
ABLY_MCP_URL=               # e.g. https://your-mcp-server.example.com/mcp
ABLY_MCP_AUTH=              # optional — CI only; a pre-obtained bearer token (never committed/logged)
