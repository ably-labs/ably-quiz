# Copy to .env.local (gitignored) and fill in what you have.
# Missing keys are skipped gracefully — see CLAUDE.md.

# --- AI models — all agents answer through the Vercel AI Gateway (one key) ---
AI_GATEWAY_API_KEY=         # required for agents — unified billing/routing for every provider
                            # (https://vercel.com/docs/ai-gateway). Models addressed as provider/model.
ANTHROPIC_API_KEY=          # only for GROUNDED turns — the MCP connector is a direct-Anthropic
                            # feature the gateway can't carry, so grounded Anthropic turns bypass it.
# OPENAI_API_KEY / XAI_API_KEY are no longer needed — those providers route through the gateway.

# --- Ably (needed from S1) ---
ABLY_API_KEY=               # server-side only; never NEXT_PUBLIC_*

# --- MCP grounding (optional) — lets agents look up your company knowledge ---
# Point this at YOUR MCP server's Streamable-HTTP /mcp endpoint to enable (a)
# in-quiz grounding (host signs in via OAuth in-app) and (b) `pnpm agents:study`.
# In the quiz, agents drive the MCP tool loop CLIENT-SIDE (direct calls, ~0.1-0.3s
# each) rather than via a provider connector — so the endpoint must speak
# Streamable HTTP (/mcp), not SSE. Unset ⇒ agents play on their own knowledge.
ABLY_MCP_URL=               # e.g. https://your-mcp-server.example.com/mcp
# Comma-separated read-only tools the model may call. Keep it to FAST tools so a
# grounded turn fits the ~18s question deadline: the model converges in a few
# round-trips. Curated context/primer tools are ideal; avoid tools that fan out
# across live systems. Unset ⇒ all tools exposed (fine for study, risky live).
# Example (fast context packs): getAutomaticContext,getContextDetail
ABLY_MCP_TOOLS=
# Optional free-text steering appended to the grounding prompt — name your fast
# tools and warn off slow ones, without putting server specifics in the code.
ABLY_MCP_GUIDANCE=
ABLY_MCP_AUTH=              # optional — CI only; a pre-obtained bearer token (never committed/logged)
