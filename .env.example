# Copy to .env.local (gitignored) and fill in what you have.
# Missing keys are skipped gracefully — see CLAUDE.md.

# --- AI models — all agents answer through the Vercel AI Gateway (one key) ---
AI_GATEWAY_API_KEY=         # required for agents — unified billing/routing for every provider
                            # (https://vercel.com/docs/ai-gateway). Models addressed as provider/model.
ANTHROPIC_API_KEY=          # only for GROUNDED turns — the MCP MCP connector is a direct-Anthropic
                            # feature the gateway can't carry, so grounded Anthropic turns bypass it.
# OPENAI_API_KEY / XAI_API_KEY are no longer needed — those providers route through the gateway.

# --- Ably (needed from S1) ---
ABLY_API_KEY=               # server-side only; never NEXT_PUBLIC_*

# --- MCP MCP grounding (S6) — host authenticates in-app (OAuth); no key here ---
ABLY_OS_MCP_URL=            # optional override of the prod Worker (dev/staging)

# --- MCP-powered study (S6.3) — `pnpm agents:study`, run locally ---
# Lets agents research Ably knowledge through the read-only MCP into richer cribs.
# Needs ANTHROPIC_API_KEY (the connector). Auth is INTERACTIVE by default: the CLI
# prints an OAuth link, you sign in through Okta, it catches the loopback callback
# — no token stored. Set ABLY_MCP_AUTH only for non-interactive/CI runs.
ABLY_MCP_URL=              # optional override; defaults to the nonprod Worker /mcp endpoint
ABLY_MCP_AUTH=             # optional — CI only; a pre-obtained bearer token (never committed/logged)
